#!/usr/bin/env bash
# Battery percent for the bar (empty on desktops without battery).

bat="/sys/class/power_supply/BAT0"

if [[ ! -d "$bat" ]]; then
  echo ""
  exit 0
fi

cap="$(cat "${bat}/capacity" 2>/dev/null)"
status="$(cat "${bat}/status" 2>/dev/null)"

if [[ "$status" == "Charging" ]]; then
  echo "${cap}% +"
else
  echo "${cap}%"
fi
