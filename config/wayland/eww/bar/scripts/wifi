#!/usr/bin/env bash
# Short network status for the bar.

if command -v nmcli >/dev/null 2>&1; then
  nmcli -t -f ACTIVE,SSID dev wifi 2>/dev/null | awk -F: '$1 == "yes" { print $2; exit }'
  exit 0
fi

for iface in /sys/class/net/wl*; do
  [[ -e "$iface/operstate" ]] || continue
  if [[ "$(cat "$iface/operstate")" == "up" ]]; then
    echo "wifi"
    exit 0
  fi
done

echo "offline"
