#!/usr/bin/env bash
# Tokyo-style workspace widget for Hyprland.
# Adapted from https://github.com/raexera/tokyo

workspaces() {
  ws1=1
  ws2=2
  ws3=3
  ws4=4
  ws5=5
  ws6=6

  un="0"

  active="$(hyprctl activeworkspace -j | jq -r '.id')"
  occupied="$(hyprctl workspaces -j | jq -r '.[].id' | tr '\n' ' ')"

  o1=""; o2=""; o3=""; o4=""; o5=""; o6=""
  f1=""; f2=""; f3=""; f4=""; f5=""; f6=""

  has_ws() {
    [[ " ${occupied} " == *" $1 "* ]]
  }

  if has_ws 1; then o1=1; fi
  if has_ws 2; then o2=2; fi
  if has_ws 3; then o3=3; fi
  if has_ws 4; then o4=4; fi
  if has_ws 5; then o5=5; fi
  if has_ws 6; then o6=6; fi

  if [[ "$active" == "1" ]]; then f1=1; fi
  if [[ "$active" == "2" ]]; then f2=2; fi
  if [[ "$active" == "3" ]]; then f3=3; fi
  if [[ "$active" == "4" ]]; then f4=4; fi
  if [[ "$active" == "5" ]]; then f5=5; fi
  if [[ "$active" == "6" ]]; then f6=6; fi

  echo "(box :class \"works\" :orientation \"v\" :halign \"center\" :valign \"start\" :space-evenly \"false\" :spacing \"-5\" (button :onclick \"hyprctl dispatch workspace ${ws1}\" :class \"${un}${o1}${f1}\" \"1\") (button :onclick \"hyprctl dispatch workspace ${ws2}\" :class \"${un}${o2}${f2}\" \"2\") (button :onclick \"hyprctl dispatch workspace ${ws3}\" :class \"${un}${o3}${f3}\" \"3\") (button :onclick \"hyprctl dispatch workspace ${ws4}\" :class \"${un}${o4}${f4}\" \"4\") (button :onclick \"hyprctl dispatch workspace ${ws5}\" :class \"${un}${o5}${f5}\" \"5\") (button :onclick \"hyprctl dispatch workspace ${ws6}\" :class \"${un}${o6}${f6}\" \"6\"))"
}

workspaces

instance="$(ls "${XDG_RUNTIME_DIR}/hypr" 2>/dev/null | head -n1)"
if [[ -n "$instance" ]]; then
  socat -u "UNIX-CONNECT:${XDG_RUNTIME_DIR}/hypr/${instance}/.socket2.sock" - | while read -r _; do
    workspaces
  done
fi
